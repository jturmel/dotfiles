{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "plugin": [
    "oh-my-opencode@latest",
    "opencode-gemini-auth@latest"
  ],
  "provider": {
    "google": {
      "options": {
        "projectId": "turmel"
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "unsloth/qwen3.5-27b": {
          "name": "unsloth/qwen3.5-27b"
        },
        "openai/gpt-oss-20b": {
          "name": "openai/gpt-oss-20b"
        },
        "toolace-2.5-llama-3.1-8b": {
          "name": "toolace-2.5-llama-3.1-8b"
        },
        "ibm/granite-3.1-8b": {
          "name": "ibm/granite-3.1-8b"
        }
      }
    }
  },
  "formatter": {
    "ruff": {
      "enabled": true
    }
  },
  "mcp": {
    "cloudflare": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "oauth": {}
    },
    "crawl4ai": {
      "enabled": false,
      "type": "remote",
      "url": "http://localhost:11235/mcp/sse"
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    }
  }
}
