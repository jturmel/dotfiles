{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "autoupdate": "notify",
  "plugin": [
    "oh-my-opencode@latest",
    "opencode-gemini-auth@latest"
  ],
  "provider": {
    "google": {
      "options": {
        "projectId": "turmel"
      }
    }
  },
  "formatter": {
    "ruff": {
      "enabled": true
    }
  },
  "mcp": {
    "cloudflare": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "oauth": {}
    },
    "crawl4ai": {
      "enabled": false,
      "type": "remote",
      "url": "http://localhost:11235/mcp/sse"
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    }
  }
}
