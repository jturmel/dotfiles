{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "plugin": [
    "opencode-gemini-auth@latest",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "cleat@git+https://github.com/jturmel/cleat.git#v0.4.0",
    "opencode-ralph-loop"
  ],
  "provider": {
    "google": {
      "options": {
        "projectId": "turmel"
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {}
    }
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
      "temperature": 0.1,
      "mode": "primary"
    },
    "build": {
      "model": "openai/gpt-5.3-codex",
      "mode": "primary",
      "reasoningEffort": "medium",
      "temperature": 0.1
    },
    "build-quick": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "mode": "primary"
    },
    "build-subagent": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "mode": "subagent"
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1",
      "mode": "subagent"
    },
    "code-reviewer": {
      "name": "Code Reviewer",
      "model": "google/gemini-3.1-pro-preview",
      "reasoningEffort": "high",
      "temperature": 0.1,
      "mode": "primary"
    }
  },
  "formatter": {
    "ruff": {
      "enabled": true
    }
  },
  "permission": {
    "external_directory": {
      "/tmp": "allow",
      "env:$TMPDIR": "allow"
    }
  },
  "mcp": {
    "cloudflare": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "oauth": {}
    },
    "crawl4ai": {
      "enabled": false,
      "type": "remote",
      "url": "http://localhost:11235/mcp/sse"
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--headless"
      ]
    },
    "brave-search": {
      "enabled": true,
      "type": "local",
      "command": [
        "docker", "run", "-i", "--rm", "-e", "BRAVE_API_KEY", "-e", "BRAVE_MCP_TRANSPORT", "docker.io/mcp/brave-search"
      ],
      "environment": {
        "BRAVE_MCP_TRANSPORT": "stdio",
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    },
    "agentation": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "agentation-mcp",
        "server"
      ],
      "enabled": false,
      "environment": {}
    }
  }
}
