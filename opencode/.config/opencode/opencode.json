        "gpt-5.4-medium": {
          "name": "GPT-5.4"
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex"
        },
        "gpt-5.2": {
          "name": "GPT-5.2"
        },
        "gemini-3.1-pro": {
