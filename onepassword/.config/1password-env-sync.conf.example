# Copy this file to ~/.config/1password-env-sync.conf and set your Environment ID.
# Find it in 1Password: Developer > View Environments > View environment >
# Manage environment > Copy environment ID
OP_ENVIRONMENT_ID=""

# Optional: pin sync to a specific 1Password account when you use multiple
# accounts. Use the account sign-in address or account ID.
OP_ACCOUNT_IDENTIFIER=""
