#!/usr/bin/env bash

set -u

CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/1password-env-sync.conf"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/1password-env-sync"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/1password-env-sync"
LAST_KEYS_FILE="$STATE_DIR/last-keys"
CURRENT_ENV_FILE="$RUNTIME_DIR/current.sh"

log() {
  printf '1password-env-sync: %s\n' "$*" >&2
}

fail_open() {
  log "$1"
  exit 0
}

if [[ ! -r "$CONFIG_FILE" ]]; then
  fail_open "config file not found: $CONFIG_FILE"
fi

# shellcheck disable=SC1090
. "$CONFIG_FILE"

if [[ -z "${OP_ENVIRONMENT_ID:-}" ]]; then
  fail_open "OP_ENVIRONMENT_ID is not set in $CONFIG_FILE"
fi

declare -a op_account_args=()
if [[ -n "${OP_ACCOUNT_IDENTIFIER:-}" ]]; then
  op_account_args=(--account "$OP_ACCOUNT_IDENTIFIER")
fi

for command_name in op timeout systemctl dbus-update-activation-environment env; do
  if ! command -v "$command_name" >/dev/null 2>&1; then
    fail_open "required command not found: $command_name"
  fi
done

mkdir -p "$STATE_DIR" || fail_open "could not create state directory: $STATE_DIR"
mkdir -p "$RUNTIME_DIR" || fail_open "could not create runtime directory: $RUNTIME_DIR"

tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/1password-env-sync.XXXXXX")" || fail_open "could not create temp directory"
trap 'rm -rf "$tmpdir"' EXIT

if command -v 1password >/dev/null 2>&1; then
  if command -v systemd-run >/dev/null 2>&1; then
    systemd-run --user --quiet --collect --unit "1password-env-sync-app-$$" 1password --silent >/dev/null 2>&1 || true
  else
    1password --silent >/dev/null 2>&1 &
  fi
fi

keys_file="$tmpdir/keys.env"
if ! timeout --signal=TERM 45s op environment read "${op_account_args[@]}" "$OP_ENVIRONMENT_ID" >"$keys_file" 2>"$tmpdir/read.err"; then
  fail_open "op environment read skipped: $(tr '\n' ' ' < "$tmpdir/read.err")"
fi

declare -a keys=()

while IFS= read -r line; do
  case "$line" in
    ''|'#'*)
      continue
      ;;
    export\ *)
      line=${line#export }
      ;;
  esac

  name=${line%%=*}
  if [[ "$name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
    keys+=("$name")
  fi
done <"$keys_file"

if (( ${#keys[@]} == 0 )); then
  fail_open "no environment variables were returned for $OP_ENVIRONMENT_ID"
fi

resolved_env_file="$tmpdir/resolved.env"
if ! timeout --signal=TERM 45s op run "${op_account_args[@]}" --environment "$OP_ENVIRONMENT_ID" -- env -0 >"$resolved_env_file" 2>"$tmpdir/run.err"; then
  fail_open "op run skipped: $(tr '\n' ' ' < "$tmpdir/run.err")"
fi

declare -A wanted=()
declare -a assignments=()

for name in "${keys[@]}"; do
  wanted["$name"]=1
done

while IFS= read -r -d '' entry; do
  name=${entry%%=*}
  if [[ -n "${wanted[$name]+x}" ]]; then
    assignments+=("$entry")
  fi
done <"$resolved_env_file"

if (( ${#assignments[@]} == 0 )); then
  fail_open "no resolved environment assignments were produced for $OP_ENVIRONMENT_ID"
fi

declare -a stale_keys=()

if [[ -r "$LAST_KEYS_FILE" ]]; then
  while IFS= read -r name; do
    [[ -n "$name" && -z "${wanted[$name]+x}" ]] && stale_keys+=("$name")
  done <"$LAST_KEYS_FILE"
fi

if (( ${#stale_keys[@]} > 0 )); then
  systemctl --user unset-environment "${stale_keys[@]}" >/dev/null 2>&1 || true
fi

if ! systemctl --user set-environment "${assignments[@]}"; then
  fail_open "failed to update the systemd user environment"
fi

if ! dbus-update-activation-environment --systemd "${assignments[@]}"; then
  log "failed to update the D-Bus activation environment"
fi

tmp_env_file="$tmpdir/current.sh"
umask 077
{
  printf '# Generated by 1password-env-sync.\n'
  for name in "${stale_keys[@]}"; do
    printf 'unset %s\n' "$name"
  done
  for entry in "${assignments[@]}"; do
    name=${entry%%=*}
    value=${entry#*=}
    printf 'export %s=%q\n' "$name" "$value"
  done
} >"$tmp_env_file" || fail_open "failed to write shell environment file"

mv "$tmp_env_file" "$CURRENT_ENV_FILE" || fail_open "failed to update shell environment file"

printf '%s\n' "${keys[@]}" >"$LAST_KEYS_FILE" || true

log "updated ${#assignments[@]} variables from $OP_ENVIRONMENT_ID"
